{
  "design_name": "Cognitive_Audit_Kernel_Demo",
  "description": "企业级智能体行为红线硬拦截因果图（认知审计内核演示）",
  "inputs": ["raw_prompt_stream"],
  "outputs": ["pim_final_anchor"],
  "operators": [
    {
      "op_type": "NS",
      "inputs": ["raw_prompt_stream"],
      "outputs": ["stripped_logic"],
      "params": {
        "strip_level": "absolute_formal"
      }
    },
    {
      "op_type": "IAP",
      "inputs": ["stripped_logic"],
      "outputs": ["verified_premise", "violation_flag"],
      "params": {
        "forbidden_matrix_active": true,
        "target_weight": 0.90
      }
    },
    {
      "op_type": "CCS",
      "inputs": ["verified_premise", "violation_flag"],
      "outputs": ["synced_audit_state"],
      "params": {
        "sync_mode": "strict_barrier"
      }
    },
    {
      "op_type": "STATE",
      "inputs": ["synced_audit_state"],
      "outputs": ["pim_final_anchor"],
      "params": {
        "update_mode": "in_situ_evolve"
      }
    }
  ]
}
